@using System.Globalization
@inject VisitorCounterStore VisitorCounter

@{
    var visitTotal = VisitorCounter.GetTotal();
}

<section id="visitors" class="relative scroll-mt-20 overflow-hidden py-20 sm:py-24 lg:py-28">
    <div
        class="pointer-events-none absolute inset-0 bg-grid-light bg-[length:48px_48px] opacity-35 [mask-image:linear-gradient(180deg,transparent,black_25%,black_75%,transparent)] dark:bg-grid-slate dark:opacity-50">
    </div>
    <div
        class="pointer-events-none absolute inset-0 bg-hero-mesh-light opacity-70 dark:bg-hero-mesh dark:opacity-100">
    </div>

    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div data-reveal class="relative">
            <div
                class="absolute -inset-px rounded-[1.75rem] bg-[length:200%_200%] bg-gradient-to-br from-accent/35 via-cyan-400/20 to-accent-dim/25 opacity-90 blur-sm motion-safe:animate-gradient-shift motion-reduce:opacity-60 dark:from-accent/45 dark:via-cyan-400/25 dark:to-accent-dim/35">
            </div>
            <div
                class="relative overflow-hidden rounded-3xl border border-slate-200/90 bg-white/85 shadow-xl shadow-slate-900/[0.06] backdrop-blur-md dark:border-slate-800/90 dark:bg-surface-card/90 dark:shadow-black/25">
                <div
                    class="pointer-events-none absolute -right-32 top-1/2 h-72 w-72 -translate-y-1/2 rounded-full bg-accent/12 blur-3xl motion-safe:animate-float-slow dark:bg-accent/18">
                </div>
                <div
                    class="pointer-events-none absolute -left-24 bottom-0 h-48 w-48 rounded-full bg-cyan-500/10 blur-3xl dark:bg-cyan-500/15">
                </div>

                <div class="relative grid gap-12 p-8 sm:p-10 lg:grid-cols-12 lg:items-center lg:gap-14 lg:p-14">
                    <div class="lg:col-span-5">
                        <SectionEyebrow Key="visitors_eyebrow" Fallback="Stats" />
                        <h2
                            class="font-display text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">
                            <span data-i18n="visitors_title">Site visits</span>
                        </h2>
                        <p class="mt-5 text-base leading-relaxed text-slate-600 dark:text-slate-400 sm:text-lg">
                            <span data-i18n="visitors_lead">We count opens of this site — each browser tab session is recorded at most once until you close it.</span>
                        </p>
                    </div>

                    <div class="flex justify-center lg:col-span-7 lg:justify-end">
                        <div class="relative w-full max-w-[17.5rem] sm:max-w-xs">
                            <div
                                class="absolute -inset-3 rounded-[1.65rem] bg-gradient-to-br from-accent/20 via-transparent to-accent-dim/15 opacity-80 dark:from-accent/25 dark:to-accent-dim/25">
                            </div>
                            <div
                                class="relative rounded-2xl border border-slate-200/90 bg-gradient-to-b from-white to-slate-50/95 p-8 text-center shadow-inner shadow-slate-900/[0.03] dark:border-slate-700/80 dark:from-surface-muted/90 dark:to-surface-card/95 dark:shadow-black/20 sm:p-9">
                                <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-accent/12 text-accent shadow-[0_0_32px_-8px_rgba(34,211,238,0.45)] ring-1 ring-accent/25 dark:bg-accent/15 dark:ring-accent/30"
                                    aria-hidden="true">
                                    <svg class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.75"
                                        viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                            d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                                    </svg>
                                </div>
                                <p class="mt-6 text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-500 dark:text-slate-500"
                                    data-i18n="visitors_label">Total opens</p>
                                <p id="pds-visitor-count"
                                    class="mt-3 bg-gradient-to-r from-accent via-accent-glow to-accent bg-clip-text font-display text-5xl font-bold tabular-nums tracking-tight text-transparent drop-shadow-[0_0_28px_rgba(34,211,238,0.25)] sm:text-6xl"
                                    data-total="@visitTotal" aria-live="polite">
                                    @visitTotal.ToString("N0", CultureInfo.InvariantCulture)
                                </p>
                                <div class="mx-auto mt-6 h-1 w-16 overflow-hidden rounded-full bg-slate-200/90 dark:bg-slate-700/80"
                                    aria-hidden="true">
                                    <div
                                        class="h-full w-1/2 rounded-full bg-gradient-to-r from-accent-dim via-accent to-accent-glow motion-safe:animate-line-glow">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
