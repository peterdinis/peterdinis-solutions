@page "/Error"
@layout MainLayout
@using System.Diagnostics
@inject IHostEnvironment HostEnvironment

<PageTitle>Error | Peterdinis Solutions</PageTitle>

<HeadContent>
    <meta name="robots" content="noindex, nofollow" />
</HeadContent>

<section
    class="relative overflow-hidden border-b border-slate-200/90 dark:border-slate-800/60">
    <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-br from-red-500/5 via-transparent to-accent/5 dark:from-red-500/10">
    </div>
    <div
        class="pointer-events-none absolute inset-0 bg-grid-light bg-[length:48px_48px] opacity-40 [mask-image:linear-gradient(180deg,transparent,black_40%,black_60%,transparent)] dark:bg-grid-slate dark:opacity-60">
    </div>

    <div class="relative mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28 lg:px-8">
        <div class="mx-auto max-w-2xl motion-safe:animate-fade-up">
            <p class="mb-4 text-center text-sm font-semibold uppercase tracking-[0.2em] text-red-500 dark:text-red-400"
                data-i18n="error_eyebrow">Error</p>
            <div class="rounded-3xl border border-slate-200/90 bg-white/90 p-8 shadow-xl backdrop-blur-sm dark:border-slate-800/80 dark:bg-surface-card/95 sm:p-10">
                <h1 class="font-display text-2xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-3xl"
                    data-i18n="error_title">
                    Something went wrong</h1>
                <p class="mt-4 text-base leading-relaxed text-slate-600 dark:text-slate-400" data-i18n="error_lead">
                    An error occurred while processing your request. Please try again later.</p>

                @if (ShowRequestId)
                {
                    <p class="mt-6 rounded-xl border border-slate-200/80 bg-slate-50 px-4 py-3 text-sm dark:border-slate-700 dark:bg-slate-900/50">
                        <span class="font-medium text-slate-700 dark:text-slate-300" data-i18n="error_request_label">Request ID</span>
                        <code
                            class="mt-1 block break-all font-mono text-xs text-slate-800 dark:text-slate-200">@RequestId</code>
                    </p>
                }

                <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                    <a href="/" data-i18n="error_try_home"
                        class="inline-flex flex-1 items-center justify-center rounded-full bg-accent px-6 py-3 text-sm font-semibold text-surface shadow-glow transition hover:bg-accent-glow sm:flex-none">
                        Back home
                    </a>
                    <a href="#contact" data-i18n="error_contact"
                        class="inline-flex flex-1 items-center justify-center rounded-full border border-slate-300 px-6 py-3 text-sm font-semibold text-slate-800 transition hover:border-accent/50 hover:bg-slate-50 dark:border-slate-600 dark:text-white dark:hover:bg-white/5 sm:flex-none">
                        Contact
                    </a>
                </div>

                @if (HostEnvironment.IsDevelopment())
                {
                    <div
                        class="mt-10 border-t border-slate-200 pt-8 dark:border-slate-700">
                        <h2 class="text-sm font-semibold uppercase tracking-wider text-amber-600 dark:text-amber-400"
                            data-i18n="error_dev_title">Development mode</h2>
                        <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400" data-i18n="error_dev_p1">
                            The Development environment shows more detailed error information for debugging.</p>
                        <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400" data-i18n="error_dev_p2">
                            Do not enable Development in production. Set ASPNETCORE_ENVIRONMENT to Development locally and restart.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
