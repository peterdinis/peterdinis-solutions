@page "/not-found"
@layout MainLayout

<PageTitle>404 — Page Not Found | Peterdinis Solutions</PageTitle>

<HeadContent>
    <meta name="robots" content="noindex, nofollow" />
</HeadContent>

<section
    class="relative overflow-hidden border-b border-slate-200/90 dark:border-slate-800/60">
    <div class="pointer-events-none absolute inset-0 bg-hero-mesh-light opacity-60 dark:bg-hero-mesh dark:opacity-100">
    </div>
    <div
        class="pointer-events-none absolute inset-0 bg-grid-light bg-[length:48px_48px] opacity-50 [mask-image:linear-gradient(180deg,transparent,black_40%,black_60%,transparent)] dark:bg-grid-slate dark:opacity-100">
    </div>

    <div class="relative mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28 lg:px-8">
        <div class="mx-auto max-w-lg text-center motion-safe:animate-fade-up">
            <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-accent" data-i18n="notfound_eyebrow">404</p>
            <p class="font-display text-7xl font-bold tabular-nums leading-none text-slate-200 dark:text-slate-800 sm:text-8xl"
                aria-hidden="true">404</p>
            <h1 class="mt-6 font-display text-2xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-3xl"
                data-i18n="notfound_title">
                Page not found</h1>
            <p class="mt-4 text-base leading-relaxed text-slate-600 dark:text-slate-400" data-i18n="notfound_body">
                That URL doesn&apos;t exist on this site.</p>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-500" data-i18n="notfound_hint">
                Check the URL or return to the home page.</p>

            <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
                <a href="/" data-i18n="notfound_back"
                    class="inline-flex w-full items-center justify-center rounded-full bg-accent px-8 py-3.5 text-sm font-semibold text-surface shadow-glow transition duration-300 ease-smooth hover:bg-accent-glow sm:w-auto">
                    Back home
                </a>
                <a href="#contact" data-i18n="notfound_contact"
                    class="inline-flex w-full items-center justify-center rounded-full border border-slate-300 px-8 py-3.5 text-sm font-semibold text-slate-800 transition duration-300 ease-smooth hover:border-accent/50 hover:bg-slate-50 hover:text-accent dark:border-slate-600 dark:text-white dark:hover:bg-white/5 sm:w-auto">
                    Contact
                </a>
            </div>
        </div>
    </div>
</section>
