@page "/analytics"
@using PeterdinisSolutions.Services
@inject VisitorCounterStore VisitorStore

<PageTitle>Analytics — Peterdinis Solutions</PageTitle>

<main class="relative min-h-screen pt-24 pb-12 overflow-hidden px-4 sm:px-6 lg:px-8">
    <!-- Background Accents -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
        <div class="absolute -top-24 -left-24 w-96 h-96 bg-accent/5 blur-[100px] rounded-full"></div>
        <div class="absolute top-1/2 -right-24 w-80 h-80 bg-cyan-500/5 blur-[100px] rounded-full"></div>
    </div>

    <div class="relative max-w-4xl mx-auto" data-reveal>
        <!-- Header Section -->
        <header class="mb-12 text-center">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/10 border border-accent/20 mb-4">
                <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
                <span class="text-[11px] font-bold uppercase tracking-wider text-accent" data-i18n="visitors_eyebrow">Statistics</span>
            </div>
            
            <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4" data-i18n="analytics_title">
                Traffic Overview
            </h1>
            
            <p class="text-base text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed" data-i18n="analytics_lead">
                Statistics on how users interact with my services and solutions.
            </p>
        </header>

        <!-- Stats Grid -->
        <div class="grid gap-6 sm:grid-cols-1 lg:grid-cols-2">
            <!-- Total Visitors Card -->
            <div class="group relative p-8 rounded-3xl bg-white/70 dark:bg-slate-900/50 backdrop-blur-xl border border-slate-200/80 dark:border-slate-800/80 shadow-sm hover:shadow-xl hover:border-accent/30 transition-all duration-300">
                <div class="absolute inset-0 bg-gradient-to-br from-accent/[0.03] to-transparent opacity-0 group-hover:opacity-100 rounded-3xl transition-opacity duration-500"></div>
                
                <div class="relative flex flex-col gap-6">
                    <div class="flex items-center justify-between">
                        <div class="w-12 h-12 rounded-2xl bg-accent/10 flex items-center justify-center text-accent">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </div>
                        <div class="flex items-center gap-1.5 text-emerald-500 bg-emerald-500/10 px-2.5 py-1 rounded-full text-xs font-medium">
                            <span class="w-1 h-1 rounded-full bg-emerald-500"></span>
                            Live
                        </div>
                    </div>

                    <div>
                        <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1" data-i18n="analytics_total">Total visitor sessions</p>
                        <div class="text-6xl font-black tracking-tighter tabular-nums text-slate-900 dark:text-white">
                            @totalVisitors
                        </div>
                    </div>
                    
                    <div class="pt-4 border-t border-slate-100 dark:border-slate-800/50">
                        <p class="text-[11px] text-slate-500 italic max-w-xs" data-i18n="visitors_lead">
                            We count session starts — each unique browser session is counted at most once.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Platform Health -->
            <div class="p-8 rounded-3xl bg-slate-50/50 dark:bg-slate-900/30 border border-slate-100 dark:border-slate-800 flex flex-col gap-6">
                <div class="flex items-center justify-between">
                    <h3 class="text-sm font-bold uppercase tracking-widest text-slate-400">Platform Health</h3>
                    <div class="flex gap-1">
                        <div class="w-1 h-3 rounded-full bg-emerald-500/60"></div>
                        <div class="w-1 h-5 rounded-full bg-emerald-500"></div>
                        <div class="w-1 h-3 rounded-full bg-emerald-500/60"></div>
                    </div>
                </div>

                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-slate-600 dark:text-slate-400">Response Rate</span>
                        <span class="text-sm font-bold text-emerald-500">99.9%</span>
                    </div>
                    <div class="w-full h-1.5 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
                        <div class="h-full w-[99.9%] bg-emerald-500"></div>
                    </div>

                    <div class="flex items-center justify-between">
                        <span class="text-sm text-slate-600 dark:text-slate-400">Server Latency</span>
                        <span class="text-sm font-bold text-accent">&lt; 40ms</span>
                    </div>
                    <div class="w-full h-1.5 bg-slate-200 dark:bg-slate-800 rounded-full overflow-hidden">
                        <div class="h-full w-[12%] bg-accent"></div>
                    </div>
                </div>

                <div class="mt-auto flex items-center gap-3 p-3 rounded-2xl bg-white dark:bg-slate-800/50 border border-slate-100 dark:border-slate-800 shadow-sm">
                    <div class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></div>
                    <span class="text-xs font-semibold text-slate-700 dark:text-slate-300">All systems operational</span>
                </div>
            </div>
            
            <!-- Tech Stack Snapshot -->
            <div class="p-8 rounded-3xl bg-slate-50/50 dark:bg-slate-900/30 border border-slate-100 dark:border-slate-800">
                <h3 class="text-sm font-bold uppercase tracking-widest text-slate-400 mb-6">Environment</h3>
                <div class="grid grid-cols-2 gap-4">
                    <div class="p-4 rounded-2xl bg-white dark:bg-slate-800/30 border border-slate-100 dark:border-slate-800">
                        <p class="text-[10px] text-slate-500 uppercase font-bold mb-1">Runtime</p>
                        <p class="text-sm font-bold">.NET 10.0</p>
                    </div>
                    <div class="p-4 rounded-2xl bg-white dark:bg-slate-800/30 border border-slate-100 dark:border-slate-800">
                        <p class="text-[10px] text-slate-500 uppercase font-bold mb-1">Location</p>
                        <p class="text-sm font-bold">Western Europe</p>
                    </div>
                </div>
            </div>

            <!-- Global Coverage Placeholder -->
            <div class="p-8 rounded-3xl bg-gradient-to-br from-accent/5 to-transparent border border-accent/10 flex flex-col justify-center items-center text-center">
                <div class="w-16 h-16 rounded-full bg-accent/10 flex items-center justify-center text-accent mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <h4 class="text-lg font-bold mb-2">Expanding Presence</h4>
                <p class="text-xs text-slate-500 leading-relaxed">Monitoring traffic patterns from 12+ regions worldwide to optimize edge delivery.</p>
            </div>
        </div>
    </div>
</main>

@code {
    private long totalVisitors;

    protected override async Task OnInitializedAsync()
    {
        totalVisitors = VisitorStore.GetTotal();
    }
}
